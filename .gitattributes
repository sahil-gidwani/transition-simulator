# Normalize all text files to LF in the repo and on checkout
* text=auto eol=lf

# Windows scripts that require CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files — never normalize
*.parquet binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.pdf binary
