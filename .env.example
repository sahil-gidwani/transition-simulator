# Precedent environment variables.
# Every variable is optional - all defaults work with no .env present.
# Copy this file to .env at the repo root to override.

# ---- Server (FastAPI, read via pydantic-settings with the PRECEDENT_ prefix) ----

# Port the API server listens on. The Vite dev proxy targets the same value,
# so changing it here re-points both sides. The dev entrypoint (npm run dev,
# or python -m app) reads it via Settings; if you invoke uvicorn directly,
# pass it yourself: uvicorn app.main:app --port "${PRECEDENT_PORT:-8000}"
PRECEDENT_PORT=8000

# Directory holding the processed data artifacts the server reads at startup.
# Relative paths resolve against server/; absolute paths are allowed.
PRECEDENT_DATA_DIR=data/processed

# ---- Client (Vite; only VITE_-prefixed variables reach browser code) ----

# Base path or URL for API calls. The default /api keeps requests same-origin;
# in dev the Vite server proxies /api -> http://127.0.0.1:${PRECEDENT_PORT}.
VITE_API_BASE=/api

# ---- Docker (docker compose up) ----

# Host port the app is published on. The client container serves the built UI
# and proxies /api to the server container (single origin), so this is the
# only port docker compose exposes.
PRECEDENT_APP_PORT=8080

# ---- Offline data acquisition (server/scripts/download_data.py) ----

# Kaggle API credentials, needed ONLY to download the raw dataset; the served
# app makes no network calls. Get a token: kaggle.com -> Settings -> API ->
# "Create New Token", then copy the username/key from the downloaded kaggle.json.
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key
